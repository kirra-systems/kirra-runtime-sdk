# /etc/kirra/ota.env — app-level A/B config for kirra-ota-ctl (edit for your box).
# The two governor install slots (each holds a `KIRRA_OTA_GOVERNOR_BIN` binary).
KIRRA_OTA_SLOT_A=/opt/kirra/slots/a
KIRRA_OTA_SLOT_B=/opt/kirra/slots/b
# The durable boot record (its parent dir must be on ReadWritePaths in the unit).
KIRRA_OTA_BOOT_RECORD=/var/lib/kirra/boot-record.json
# The governor executable's file name WITHIN a slot dir.
KIRRA_OTA_GOVERNOR_BIN=kirra-governor

# --- pull agent (kirra-ota-pull.service) ---
# The verifier base URL (its /fleet/campaigns/assignment/{node_id} is polled).
KIRRA_VERIFIER_URL=http://verifier.example:8090
# This node's id (the campaign rollout bucket is salted by it) and its cohort ring.
KIRRA_NODE_ID=robot-01
KIRRA_NODE_COHORTS=canary
# Content-addressed artifact store; the artifact is fetched from {base}/{digest}.
KIRRA_OTA_ARTIFACT_BASE=https://artifacts.example/governor
# The systemd unit `probe` restarts on rollback (default kirra-governor).
KIRRA_OTA_UNIT=kirra-governor

# --- adoption report (kirra-ota-ctl report) ---
# The report route is identity-gated (a node write needs a credential): a Bearer API
# token (integrator-role principal) + the x-kirra-client-id identity header.
KIRRA_API_TOKEN=replace-with-integrator-token
KIRRA_CLIENT_ID=robot-01
