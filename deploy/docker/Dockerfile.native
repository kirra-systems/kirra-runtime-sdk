# #686: digest-pinned base image (Dependabot `docker` bumps it). Tag kept for readability.
FROM rust:1.97-slim-bookworm@sha256:99e09cb2284e2ddbb73a995deee3e91783fd04d177602ccf6eab326d778ee777 AS builder

WORKDIR /build
COPY . .
RUN cargo build --release

# #686: digest-pinned base image (Dependabot `docker` bumps it).
FROM debian:bookworm-slim@sha256:7b140f374b289a7c2befc338f42ebe6441b7ea838a042bbd5acbfca6ec875818

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /opt/kirra

COPY --from=builder /build/target/release/kirra_verifier_service /opt/kirra/
COPY --from=builder /build/config /opt/kirra/config

ENV KIRRA_SUPERVISOR_RESET_KEY=""

EXPOSE 5502 5503 5504 8080

CMD ["/opt/kirra/kirra_verifier_service"]
