<?xml version="1.0"?>
<?xml-model href="http://download.ros.org/schema/package_format3.xsd" schematypens="http://www.w3.org/2001/XMLSchema"?>
<package format="3">
  <!--
    CURATED INTERFACE PACKAGE — real Autoware package name, VERBATIM subset.

    This is the Kirra-curated `autoware_perception_msgs` carrying ONLY the
    message closure the governor actually consumes (the PredictedObjects tree).
    The package NAME is the real Autoware name and the msg/*.msg are
    BYTE-IDENTICAL copies of the deployed Autoware version, so the RIHS type
    hash matches and DDS delivers genuine Autoware messages to the governor.

    The msg/ directory is populated by
    scripts/curated_interface/extract_closures.sh from a reference Autoware
    install — NEVER hand-edited (any edit to a .msg silently breaks wire
    compatibility). The byte-identical guarantee is the version-sync SRAC
    (docs/safety/MSG_INTERFACE_VERSION_SYNC.md, KIRRA-OCCY-MSGSYNC-001).

    NOTE on <version>: the package version below is metadata only — DDS/RIHS
    wire compatibility is determined by the message-closure structure (the
    verbatim .msg + the base-message versions from ros-base), NOT by this
    field. The pinned reference Autoware version is recorded in the SRAC.
  -->
  <name>autoware_perception_msgs</name>
  <version>0.0.0</version>
  <description>
    Kirra-curated subset of autoware_perception_msgs (PredictedObjects closure
    only), verbatim/hash-verified for the independent governor's isolated
    interface surface. See docs/safety/MSG_INTERFACE_VERSION_SYNC.md.
  </description>
  <maintainer email="safety@kirra.systems">Kirra Safety</maintainer>
  <license>Apache-2.0</license>

  <buildtool_depend>ament_cmake</buildtool_depend>
  <buildtool_depend>rosidl_default_generators</buildtool_depend>

  <depend>std_msgs</depend>
  <depend>geometry_msgs</depend>
  <depend>builtin_interfaces</depend>
  <depend>unique_identifier_msgs</depend>

  <exec_depend>rosidl_default_runtime</exec_depend>
  <member_of_group>rosidl_interface_packages</member_of_group>

  <export>
    <build_type>ament_cmake</build_type>
  </export>
</package>
