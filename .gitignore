target/
# The root Cargo.lock is committed: this repo ships binaries/services, so a
# pinned, reproducible dependency graph is required (prevents transitive drift
# like the alloc-no-stdlib 2.x/3.x split that broke the brotli build in CI).
# WS-0.6: parko/Cargo.lock is now committed too — the supply-chain gate
# (cargo-deny --locked) and the SBOM story need a pinned graph for BOTH
# workspaces, and parko's CI jobs get the same drift protection the root
# lock exists for. The iceoryx2 spike's lock stays ignored (host-side spike
# tool, not a shipped or gated workspace).
tools/iceoryx2-spike/Cargo.lock
data/outputs/
node_modules/
dashboard/dist/

# Next.js operator-console build artifacts (console/ source is tracked on
# main; these are generated locally and must never be committed)
.next/
out/
next-env.d.ts
*.tsbuildinfo
__pycache__/
*.pyc
*.proptest-regressions
*.profraw
*.profdata
coverage-report/
lcov.info

# cargo-mutants output (quality-hardening pass; `.run*` = kept prior runs
# for scope comparison, e.g. WP-08's own-tests vs +adapter-tests baselines)
mutants.out/
mutants.out.run*/
mutants.kill-check/

# colcon build artifacts (ros2_ws)
ros2_ws/build/
ros2_ws/install/
ros2_ws/log/

# local bootstrap scripts + SQLite verifier stores
occy_bootstrap.sh
occy_standards.sh
*.sqlite
*.sqlite-shm
*.sqlite-wal

# cargo-cyclonedx trial outputs (release SBOMs are generated in CI)
*.cdx.json
