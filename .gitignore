target/
# The root Cargo.lock is committed: this repo ships binaries/services, so a
# pinned, reproducible dependency graph is required (prevents transitive drift
# like the alloc-no-stdlib 2.x/3.x split that broke the brotli build in CI).
# Separate sub-workspaces keep their locks ignored for now.
parko/Cargo.lock
tools/iceoryx2-spike/Cargo.lock
data/outputs/
node_modules/
dashboard/dist/
__pycache__/
*.pyc
*.proptest-regressions
*.profraw
*.profdata
coverage-report/
lcov.info

# cargo-mutants output (quality-hardening pass)
mutants.out/

# colcon build artifacts (ros2_ws)
ros2_ws/build/
ros2_ws/install/
ros2_ws/log/

# local bootstrap scripts + SQLite verifier stores
occy_bootstrap.sh
occy_standards.sh
*.sqlite
*.sqlite-shm
*.sqlite-wal
